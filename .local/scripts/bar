#!/usr/bin/env sh
#
# Script to output system information to a 'bar'.
#

# shellcheck source=/dev/null
. ~/.local/scripts/clr

battery() {
    bat=$(acpi)
    sta=$(printf '%s' "$bat" | awk '{print $3}' | sed 's/,//g')
    per=$(printf '%s' "$bat" | awk '{print $4}' | sed 's/,//; s/%//')
    
    case "$per" in
        [0-9]|1[0-9])         clr="$(colors 1)"; icn="´ëä" ;;
        2[0-9]|3[0-9]|4[0-9]) clr="$(colors 3)"; icn="´ëâ" ;;
        5[0-9]|6[0-9])        clr="$(colors 4)"; icn="´ëé" ;;
        7[0-9]|8[0-9])        clr="$(colors 2)"; icn="´ëü" ;;
        *)                    clr="$(colors 7)"; icn="´ëÇ" ;;
    esac
    case "$sta" in
        "Discharging") icn="$icn" ;;
        "Charging")    icn="´âº ´çª" ;;
        "Full")        icn="´ëÇ" ;;
        *)             icn="´ä¿" ;;
    esac

    printf '%s %s %s' "$clr" "$icn" "$per%"
}

cpu() {
    cpu=$(mpstat 1 1 | sed '$!d' | awk '{print $3}')

    case "$(printf '%.f' "$cpu")" in
        [0-9]|1[0-9])         clr="$(colors 7)" ;;
        2[0-9]|3[0-9]|4[0-9]) clr="$(colors 2)" ;;
        5[0-9]|6[0-9])        clr="$(colors 4)" ;;
        7[0-9]|8[0-9])        clr="$(colors 3)" ;;
        *)                    clr="$(colors 1)" ;;
    esac

    printf '%s %s %s' "$clr" "´ç¥" "$cpu%"
}

datee() {
    printf '%s %s %s' "$(colors 7)" "´ü│" "$(date '+%Y-%m-%d')"
}

disk() {
    clr=$(colors 7)
    dsk=$(df -h -P "$HOME" | sed '$!d' | awk '{print $4}')
    printf '%s %s %s' "$clr" "´éá" "$dsk"
}

mediaplayer() {
    ply="${BLOCK_INSTANCE:-spotify}"
    arg="--player=$ply"
    art=$(playerctl "$arg" metadata artist)
    ttl=$(playerctl "$arg" metadata title)
    
    case "$BLOCK_BUTTON" in
        1) playerctl "$arg" previous ;;
        2) playerctl "$arg" play-pause ;;
        3) playerctl "$arg" next ;;
    esac
    
    [ -n "$art" ] && msg="$art"
    [ -n "$ttl" ] && msg="$ttl"
    [ -n "$art" ] && [ -n "$ttl" ] && msg="$art - $ttl"
    [ -z "$msg" ] && return
    [ -z "$DWM" ] && msg="$(printf '%s' "$msg" | sed -e 's/\&/&amp;/g')"
    
    printf '%s %s %s' "#2edb59" "´å╝" "$msg"
}

memory() {
    mem=$(free | sed -ne '/^Mem:\(.*\)/p')
    ttl=$(printf '%s' "$mem" | awk '{print $2/1024/1024}')
    fre=$(printf '%s' "$mem" | awk '{print ($4+$6)/1024/1024}')
    use=$(printf '%s\n' "$ttl - $fre" | bc -l)
    per=$(printf '%s\n' "$use / $ttl * 100" | bc -l)
    
    case "$per" in
        [0-9]|1[0-9])         clr="$(colors 1)" ;;
        2[0-9]|3[0-9]|4[0-9]) clr="$(colors 3)" ;;
        5[0-9]|6[0-9])        clr="$(colors 4)" ;;
        7[0-9]|8[0-9])        clr="$(colors 2)" ;;
        *)                    clr="$(colors 7)" ;;
    esac
    
    printf '%s %s %.f%%' "$clr" "´âë" "$per"
}

openconnect() {
    [ -n "$(pidof openconnect)" ] && clr=$(colors 2) || clr=$(colors 1)
    printf '%s %s' "$clr" "´Å¡"
}

timee() {
    printf '%s %s %s' "$(colors 6)" "´Çù" "$(date '+%H:%M')"
}

__updates() {
    aur="${1:-true}"
    sil="${2:-false}"
    mkdir -p /tmp/checkup-db-"$USER"
    sudo pacman -Sy --dbpath /tmp/checkup-db-"$USER" --logfile /dev/null >/dev/null 2>&1
    upt=$(pacman -Qu 2> /dev/null | grep -cv '\[.*\]')
    [ "$aur" = "true" ] && \
        upt=$(( upt + $(yay -Qua | wc -l) ))
    
    if [ "$upt" -gt 0 ]; then
        clr=$(colors 2)
        msg="$upt update(s)"
    elif [ "$sil" != false ]; then
        clr=$(colors 3)
        msg="sys up to date"
    fi
    
    [ -n "$clr" ] && [ -n "$msg" ] && printf '%s %s %s' "$clr" "´é½" "$msg"
}

updates() {
    case "$BLOCK_BUTTON" in
        1) __updates "$@"; return ;;
    esac

    __updates "$@"
}

rupdates() {
    [ -f "/tmp/updates" ] &&  printf '%s' "$(cat /tmp/updates)"
}

volume() {
    mix="default"
    stp="${1:-5%}"
    ctl="$(amixer -D $mix scontrols \
        | sed -n "s/Simple mixer control '\([A-Za-z ]*\)',0/\1/p; 1q")"
    cap="$(amixer -D $mix get "$ctl" \
        | sed -n 's/ \+Capabilities:.*volume.*/Capture/p')"
    dat="$(amixer -D $mix get "$ctl" "$cap" | sed '$!d')"
    vol="$(printf '%s' "$dat" | awk '{print $4}' | sed -e 's/\[\(.*\)\%\]/\1/')"
    sta="$(printf '%s' "$dat" | awk '{print $6}' | sed -e 's/\[\(.*\)\]/\1/')"
    
    [ "$sta" = "off" ] && vol=0
    case "$BLOCK_BUTTON" in
        3) notify-send "$mix $ctl" ; amixer -q -D $mix sset "$ctl" toggle ;;
        4) amixer -q -D $mix sset "$ctl" "${stp}+" unmute ;;
        5) amixer -q -D $mix sset "$ctl" "${stp}-" unmute ;;
    esac
    case "$vol" in
        0)                    icn="´Ü®" ;;
        [0-9]|1[0-9])         icn="´Çª" ;;
        2[0-9]|3[0-9])        icn="´Çº" ;;
        4[0-9]|5[0-9])        icn="´Çº" ;;
        6[0-9]|7[0-9]|8[0-9]) icn="´Ç¿" ;;
        *)                    icn="´Ç¿" ;;
    esac
    
    clr=$(colors 7)
    printf '%s %s %s' "$clr" "$icn" "$vol%"
}

wifi() {
    int="${BLOCK_INSTANCE:-wlp2s0}"
    [ ! -d "/sys/class/net/${int}/wireless" ] ||
        [ "$(cat /sys/class/net/"$int"/operstate)" = 'down' ] && return 1
    qlt="$(grep "$int" /proc/net/wireless | awk '{print int($3 * 100 / 70)}')"
    
    case "$qlt" in
        [0-9]|1[0-9])         clr=$(colors 1); icn="´ç½" ;;
        2[0-9]|3[0-9])        clr=$(colors 3); icn="´ç½" ;;
        4[0-9]|5[0-9])        clr=$(colors 4); icn="´ç½" ;;
        6[0-9]|7[0-9]|8[0-9]) clr=$(colors 2); icn="´ç½" ;;
        *)                    clr=$(colors 7); icn="´ç½" ;;
    esac
    
    printf '%s %s %s%%' "$clr" "$icn" "$qlt"
}
